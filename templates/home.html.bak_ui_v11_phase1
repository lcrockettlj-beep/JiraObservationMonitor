<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Jira Observation Monitor</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="{{ url_for('static', filename='js/theme.js') }}"></script>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/app.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/home.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/tiles.css') }}">
</head>
<body>
<div class="page">
    {% include "_nav.html" %}
    {% set change_summary = change_detection.get("summary", {}) if change_detection else {} %}
    {% set discovery_summary = site_discovery.get("summary", {}) if site_discovery else {} %}
    {% set trend_summary = historical_trends.get("summary", {}) if historical_trends else {} %}
    {% set trend_has_history = historical_trends.get("has_history") if historical_trends else False %}
    {% set trend_lookback = historical_trends.get("lookback_snapshots", 0) if historical_trends else 0 %}
    {% set snapshot_meta = latest_snapshot.get("snapshot_meta", {}) if latest_snapshot else {} %}
    
    {% set snapshot_meta = latest_snapshot.get("snapshot_meta", {}) if latest_snapshot else {} %}
    {% set latest_snapshot_timestamp =
        snapshot_meta.get("snapshot_timestamp")
        or latest_snapshot_entry.get("created_at_local")
        or latest_snapshot_entry.get("snapshot_timestamp")
        or 'Not available'
    %}

    {% set intelligence_site_total = intelligence_sites|length if intelligence_sites else 0 %}
    {% set intelligence_risk_site_total = sites_with_risks|length if sites_with_risks else 0 %}
    {% set intelligence_risk_total = intelligence_top_risks|length if intelligence_top_risks else 0 %}
    {% set intelligence_watchlist = sites_with_risks[:6] if sites_with_risks else [] %}
    {% macro site_section(title, subtitle, sites, badge_class) -%}
    <section class="panel site-section-panel">
        <div class="section-header">
            <div>
                <h2>{{ title }}</h2>
                <p>{{ subtitle }}</p>
            </div>
            <div class="section-header__actions">
                <span class="pill">{{ sites|length }} sites</span>
            </div>
        </div>
        {% if sites %}
        <div class="site-grid">
            {% for site in sites %}
            {% set site_key = site.site if site.site and site.site != 'Not Found' else '' %}
            <article class="site-card site-card--{{ badge_class }}">
                <div class="site-card__top">
                    <div>
                        <div class="site-card__title-row">
                            <h3>{{ site.site_name or site.site or 'Site' }}</h3>
                            <span class="badge badge--{{ badge_class }}">{{ site.status or badge_class }}</span>
                        </div>
                        <p class="site-card__sub">{{ site.reason or "No immediate issues detected" }}</p>
                    </div>
                    <div class="site-card__actions">
                        {% if site_key %}
                            <a href="/detail/trend::site::{{ site_key }}" class="pill">Historical View</a>
                            <a href="/detail/project::site::{{ site_key }}" class="pill">Project sample</a>
                        {% else %}
                            <span class="pill">Historical View unavailable</span>
                            <span class="pill">Project sample unavailable</span>
                        {% endif %}
                    </div>
                </div>
                <div class="metric-grid">
                    <div class="metric-box">
                        <div class="metric-label">Users</div>
                        <div class="metric-value">{{ site.total_users or 0 }}</div>
                        <div class="metric-note">Site total users</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-label">Projects</div>
                        <div class="metric-value">{{ site.project_count or 0 }}</div>
                        <div class="metric-note">Current project count</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-label">Risk</div>
                        <div class="metric-value">{{ site.risk_score or site.historical_trend_score or 0 }}</div>
                        <div class="metric-note">Current risk level</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-label">Snapshots</div>
                        <div class="metric-value">{{ site.historical_snapshot_count or site.snapshot_count or 0 }}</div>
                        <div class="metric-note">Snapshots retained</div>
                    </div>
                </div>
                <div class="delta-grid">
                    <div class="delta-chip"><span>Total users &Delta;</span><strong>{{ site.total_users_delta or 0 }}</strong></div>
                    <div class="delta-chip"><span>Projects &Delta;</span><strong>{{ site.project_count_delta_live or site.project_count_delta or 0 }}</strong></div>
                    <div class="delta-chip"><span>Risk &Delta;</span><strong>{{ site.historical_risk_delta or 0 }}</strong></div>
                    <div class="delta-chip"><span>Unresolved &Delta;</span><strong>{{ site.historical_unresolved_delta or 0 }}</strong></div>
                </div>
                
                <div class="chip-list">
                    {% if site.attention_reasons %}
                        {% for item in site.attention_reasons[:2] %}
                            <span class="chip chip--warning">{{ item }}</span>
                        {% endfor %}
                    {% endif %}

                    {% if site.historical_trend_signals %}
                        {% for item in site.historical_trend_signals[:2] %}
                            <span class="chip chip--accent">{{ item }}</span>
                        {% endfor %}
                    {% endif %}
                </div>

            </article>
            {% endfor %}
        </div>
        {% else %}
        <div class="empty-state">
            <strong>No sites in this category right now.</strong>
            <p>This section will populate automatically when site status grouping produces records for {{ title|lower }}.</p>
        </div>
        {% endif %}
    </section>
    {%- endmacro %}
    <section class="hero">
        <div class="hero__top">
            <div>
                
                <h1>Operational Overview</h1>
                <p>
                Live view of GLI's Atlassian estate — showing site health, user activity, and
                emerging risks. All data is read-only and refreshed automatically.
                </p>

            </div>
            <div class="hero__meta meta-pills">
                <span class="pill">Users rows: {{ users_row_count or 0 }}</span>
                <span class="pill">Managed rows: {{ managed_row_count or 0 }}</span>
                <span class="pill">Snapshot history depth: {{ trend_lookback or 0 }}</span>
            </div>
        </div>
    </section>
   
    <section class="source-strip">
        <div class="source-strip__item">
            <strong>Last verified snapshot:</strong>
            {{ latest_snapshot_timestamp }}
        </div>
        <div class="source-strip__item">
            <strong>Sites monitored:</strong>
            {{ discovery_summary.tracked_site_count or 0 }}
        </div>
        <div class="source-strip__item">
            <strong>Intelligence coverage:</strong>
            {{ intelligence_site_total or 0 }} analysed site(s)
        </div>
    </section>

    <section class="panel intelligence-panel">
        <div class="section-header">
            <div>
                <h2>Operational Intelligence</h2>
                <p>Key risk indicators across your sites, highlighting areas that may require attention.</p>
            </div>
            <div class="section-header__actions">
                <a href="/detail/intelligence::summary" class="pill">Intelligence summary</a>
                <span class="pill">{{ intelligence_site_total }} analysed sites</span>
            </div>
        </div>
        <div class="grid-4 stat-grid intelligence-card-grid">
            <a href="/detail/intelligence::summary" class="stat-card stat-card--link intelligence-card">
                <div class="label">Estate Risk Score</div>
                <div class="value">{{ estate_risk_score or 0 }}</div>
                <div class="note">Current intelligence estate category: <strong>{{ estate_risk_category or 'Healthy' }}</strong>.</div>
            </a>
            <a href="/detail/intelligence::summary" class="stat-card stat-card--link intelligence-card">
                <div class="label">Top Intelligence Risks</div>
                <div class="value">{{ intelligence_risk_total }}</div>
                <div class="note">Highest-severity intelligence findings currently available in the estate snapshot.</div>
            </a>
            <a href="/detail/intelligence::summary" class="stat-card stat-card--link intelligence-card">
                <div class="label">Sites With Risks</div>
                <div class="value">{{ intelligence_risk_site_total }}</div>
                <div class="note">Sites with at least one active intelligence finding and a drilldown-ready payload.</div>
            </a>
            <div class="stat-card intelligence-card intelligence-card--status intelligence-card--{{ (estate_risk_category or 'Healthy')|lower }}">
                <div class="label">Operational Posture</div>
                <div class="value">{{ estate_risk_category or 'Healthy' }}</div>
                <div class="note">Read-only intelligence state based on inactive users, unmanaged accounts, orphaned projects, app usage, and capacity checks.</div>
            </div>
        </div>
    </section>
    <section class="panel intelligence-watchlist-panel">
        <div class="section-header">
            <div>
                <h2>Intelligence Watchlist</h2>
                <p>Sites currently flagged with risk indicators, prioritised for review.</p>
            </div>
            <div class="section-header__actions">
                <a href="/detail/intelligence::summary" class="pill">View all intelligence risks</a>
            </div>
        </div>
        {% if intelligence_watchlist %}
        <div class="site-grid intelligence-watchlist-grid">
            {% for site in intelligence_watchlist %}
            {% set first_risk = site.risks[0] if site.risks else None %}
            <article class="site-card intelligence-site-card site-card--{{ (site.risk_category or 'warning')|lower }}">
                <div class="site-card__top">
                    <div>
                        <div class="site-card__title-row">
                            <h3>{{ site.name or site.site_key or site.id or 'Site' }}</h3>
                            <span class="badge badge--{{ 'critical' if (site.risk_category == 'Critical') else ('warning' if (site.risk_category == 'Warning') else 'stable') }}">{{ site.risk_category or 'Healthy' }}</span>
                        </div>
                        <p class="site-card__sub">{{ site.why_it_stands_out[0] if site.why_it_stands_out else 'No standout reason currently provided.' }}</p>
                    </div>
                    <div class="site-card__actions">
                        <a href="/detail/intelligence::summary" class="pill">Summary</a>
                        {% if first_risk and first_risk.action %}
                            <a href="{{ first_risk.action }}" class="pill">Open first drilldown</a>
                        {% endif %}
                    </div>
                </div>
                <div class="metric-grid">
                    <div class="metric-box">
                        <div class="metric-label">Risk Score</div>
                        <div class="metric-value">{{ site.risk_score or 0 }}</div>
                        <div class="metric-note">Combined weighted intelligence score</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-label">Findings</div>
                        <div class="metric-value">{{ site.risk_count or 0 }}</div>
                        <div class="metric-note">Active intelligence rows for this site</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-label">Users</div>
                        <div class="metric-value">{{ site.users_count or 0 }}</div>
                        <div class="metric-note">Users considered by intelligence engine</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-label">Projects / Apps</div>
                        <div class="metric-value">{{ site.projects_count or 0 }} / {{ site.apps_count or 0 }}</div>
                        <div class="metric-note">Objects scanned for stale/project/app signals</div>
                    </div>
                </div>
                <div class="chip-list">
                    {% if site.why_it_stands_out %}
                        {% for item in site.why_it_stands_out[:3] %}
                            <span class="chip chip--accent">{{ item }}</span>
                        {% endfor %}
                    {% endif %}
                    {% if site.risks %}
                        {% for risk in site.risks[:3] %}
                            <span class="chip chip--warning">{{ risk.type|replace('_', ' ') }} ({{ risk.count or 0 }})</span>
                        {% endfor %}
                    {% endif %}
                </div>
            </article>
            {% endfor %}
        </div>
        {% else %}
        <div class="empty-state">
            <strong>No intelligence watchlist entries are currently active.</strong>
            <p>The intelligence area is wired and ready. This section will populate as soon as active site-level findings are present in the current payload.</p>
        </div>
        {% endif %}
    </section>
    <section class="panel">
        <div class="section-header">
            <div>
                <h2>Needs Attention</h2>
                <p>Key account and access issues that may require action in Atlassian.</p>
            </div>
        </div>
        <div class="grid-4 stat-grid">
            <a href="/detail/admin::suspended_accounts" class="stat-card stat-card--link">
                <div class="label">Disabled User Accounts</div>
                <div class="value">{{ estate.managed_disabled_accounts or 0 }}</div>
                <div class="note">Managed accounts currently disabled.</div>
            </a>
            <a href="/detail/admin::managed_accounts" class="stat-card stat-card--link">
                <div class="label">Users Without Jira Access</div>
                <div class="value">{{ estate.no_tracked_jira_site_access or 0 }}</div>
                <div class="note">Accounts without tracked Jira site access in current scope.</div>
            </a>
            <a href="/detail/admin::suspended_accounts" class="stat-card stat-card--link">
                <div class="label">Inactive Users (No Access)</div>
                <div class="value">{{ estate.inactive_without_site_access or 0 }}</div>
                <div class="note">Inactive users who appear to have no tracked site access.</div>
            </a>
            <a href="/detail/billing::bitbucket_entries" class="stat-card stat-card--link">
                <div class="label">Bitbucket-only Users</div>
                <div class="value">{{ estate.bitbucket_only_no_tracked_jira or 0 }}</div>
                <div class="note">Users aligned to Bitbucket without tracked Jira presence.</div>
            </a>
        </div>

    </section>
    <section class="panel">
        <div class="section-header">
            <div>
                <h2>Change & Discovery</h2>
                <p>Recent changes and newly discovered sites across the monitored estate.</p>
            </div>
            <div class="section-header__actions">
                <a href="/detail/change::summary" class="pill">Change summary</a>
                <a href="/detail/discovery::summary" class="pill">Discovery summary</a>
            </div>
        </div>
        <div class="grid-4 stat-grid">
            <a href="/detail/change::summary" class="stat-card stat-card--link">
                <div class="label">Detected Changes</div>
                <div class="value">{{ change_summary.change_count or 0 }}</div>
                <div class="note">Latest collector comparison changes.</div>
            </a>
            <a href="/detail/change::site_attention" class="stat-card stat-card--link">
                <div class="label">Sites with Increasing Risk</div>
                <div class="value">{{ change_summary.rising_risk_site_count or 0 }}</div>
                <div class="note">Sites showing positive historical risk movement.</div>
            </a>
            <a href="/detail/discovery::summary" class="stat-card stat-card--link">
                <div class="label">Tracked Sites</div>
                <div class="value">{{ discovery_summary.tracked_site_count or 0 }}</div>
                <div class="note">Operational sites currently in scope.</div>
            </a>
            <a href="/detail/change::excluded_sites" class="stat-card stat-card--link">
                <div class="label">Excluded Sites</div>
                <div class="value">{{ change_summary.excluded_site_count or discovery_summary.excluded_site_count or 0 }}</div>
                <div class="note">Discovered but currently out-of-scope sites.</div>
            </a>
        </div>
    </section>
    <section class="panel trend-panel">
        <div class="section-header">
            <div>
                <h2>Trend Watch</h2>
                <p>Trends over time showing changes in site health, risk, and activity levels.</p>
            </div>
            <div class="section-header__actions">
                <a href="/detail/trend::summary" class="pill">Trend summary</a>
                <a href="/detail/trend::sites" class="pill">View all trend sites</a>
            </div>
        </div>
        {% if trend_has_history %}
        <div class="grid-4 stat-grid trend-card-grid">
            <a href="/detail/trend::summary" class="stat-card stat-card--link trend-card">
                <div class="label">Available snapshots</div>
                <div class="value">{{ trend_lookback or 0 }}</div>
                <div class="note">Recent snapshots available for historical comparison.</div>
            </a>
            <a href="/detail/trend::risk_risers" class="stat-card stat-card--link trend-card">
                <div class="label">Sites with Increasing Risk</div>
                <div class="value">{{ trend_summary.rising_risk_sites or 0 }}</div>
                <div class="note">Sites with a positive risk trend across snapshot history.</div>
            </a>
            <a href="/detail/trend::sites?sort=trend_score&order=desc" class="stat-card stat-card--link trend-card">
                <div class="label">Sites Repeatedly Flagged</div>
                <div class="value">{{ trend_summary.warning_or_critical_streak_sites or 0 }}</div>
                <div class="note">Sites repeatedly remaining under elevated status.</div>
            </a>
            <a href="/detail/trend::sites?sort=unresolved_delta&order=desc" class="stat-card stat-card--link trend-card">
                <div class="label">Sites with Growing Backlog</div>
                <div class="value">{{ trend_summary.rising_unresolved_sites or 0 }}</div>
                <div class="note">Sites where unresolved issue backlog is increasing.</div>
            </a>
        </div>
        {% else %}
        <div class="empty-state">
            <strong>Historical View not available yet.</strong>
            <p>Snapshot history needs to exist before historical trend cards can populate on the homepage.</p>
        </div>
        {% endif %}
    </section>
    {{ site_section('Critical Sites', 'Sites requiring immediate attention based on current status.', critical_sites, 'critical') }}
    {{ site_section('Warning Sites', 'Sites showing early warning signs or potential risk.', warning_sites, 'warning') }}
    {{ site_section('Stable Sites', 'Sites operating normally and within expected limits.', stable_sites, 'stable') }}
</div>
<script>
    window.JOMTheme.initToggle("theme-toggle");
</script>
  <script src="{{ url_for('static', filename='js/dashboard_refresh.js') }}"></script>
</body>
</html>

